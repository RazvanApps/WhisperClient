# Line ending configuration — ensures consistent LF for Linux-deployed files
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf

# Infrastructure files
*.sh text eol=lf
**/Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-specific
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.exe binary
