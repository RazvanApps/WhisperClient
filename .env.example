# WhisperClient Environment Configuration
# Copy this file to .env and edit as needed
# These values override the default config.json settings

# Whisper Server URL (OpenAI-compatible endpoint)
# Default: http://localhost:8000/v1/audio/transcriptions
WHISPER_SERVER_URL=http://localhost:8000/v1/audio/transcriptions

# Optional: OpenAI API key for GPT text refinement
# Leave empty to disable GPT refinement
OPENAI_API_KEY=

# Optional: Default language for transcription
# Examples: en, ro, de, fr, es, auto (empty for auto-detect)
WHISPER_LANGUAGE=en
